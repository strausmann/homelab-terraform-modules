# --- Proxmox Verbindung ---
# Kopiere diese Datei nach terraform.tfvars und trage deine Werte ein.
# terraform.tfvars wird NICHT committed (.gitignore).

proxmox_url       = "https://pve.example.com:8006/"
proxmox_api_token = "terraform@pve!homelab=DEIN_TOKEN_HIER"
proxmox_skip_tls  = true
proxmox_node      = "pve"
